# Copy this file to .env.local for local development
# Or set these in Vercel dashboard for production

# For local development:
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_API_URL=http://localhost:5000

# For production (after deploying backend to VPS):
# NEXT_PUBLIC_SOCKET_URL=https://your-vps-domain.com:5000
# NEXT_PUBLIC_API_URL=https://your-vps-domain.com:5000